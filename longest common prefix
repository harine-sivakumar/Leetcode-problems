class Solution:
    def longestCommonPrefix(self, strs: list[str]) -> str:
        if not strs: return ""
        # Compare characters at each position across strings
        for i, char in enumerate(strs[0]):
            for other_str in strs[1:]:
                if i >= len(other_str) or other_str[i] != char:
                    return strs[0][:i]
        return strs[0]
