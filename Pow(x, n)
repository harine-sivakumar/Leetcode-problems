class Solution:
    def myPow(self, x: float, n: int) -> float:
        # Handle negative exponents
        if n < 0:
            x = 1 / x
            n = -n
        
        result = 1.0
        current_product = x
        
        while n > 0:
            # If the current bit is 1 (n is odd), multiply the result
            if n % 2 == 1:
                result *= current_product
            
            # Square the base for the next bit position
            current_product *= current_product
            
            # Integer division to move to the next bit
            n //= 2
            
        return result
