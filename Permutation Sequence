import math

class Solution:
    def getPermutation(self, n: int, k: int) -> str:
        # Pre-calculate factorials and number list
        numbers = [i for i in range(1, n + 1)]
        fact = [1] * n
        for i in range(1, n):
            fact[i] = fact[i-1] * i
        
        # Adjust k to be 0-indexed
        k -= 1
        result = []
        
        # Iterate to build the permutation string
        for i in range(n - 1, -1, -1):
            index = k // fact[i]
            k %= fact[i]
            
            result.append(str(numbers.pop(index)))
            
        return "".join(result)
