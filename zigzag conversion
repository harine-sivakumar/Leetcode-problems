class Solution:
    def convert(self, s: str, numRows: int) -> str:
        # Edge case: if only one row, or string is too short, no zigzag happens
        if numRows == 1 or numRows >= len(s):
            return s
        
        # Create a list of strings for each row
        rows = ["" for _ in range(numRows)]
        curr_row = 0
        direction = -1  # Will flip to 1 (down) immediately
        
        for char in s:
            rows[curr_row] += char
            
            # If at top or bottom row, reverse direction
            if curr_row == 0 or curr_row == numRows - 1:
                direction *= -1
            
            curr_row += direction
            
        # Join all rows together for the final result
        return "".join(rows)
