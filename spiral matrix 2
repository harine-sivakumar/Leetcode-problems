class Solution:
    def generateMatrix(self, n: int) -> list[list[int]]:
        # 1. Initialize the n x n matrix with zeros
        matrix = [[0] * n for _ in range(n)]
        
        # 2. Define the initial boundaries
        top, bottom = 0, n - 1
        left, right = 0, n - 1
        
        curr_val = 1
        
        # 3. Fill the matrix while boundaries are valid
        while left <= right and top <= bottom:
            # Move Right: top row
            for i in range(left, right + 1):
                matrix[top][i] = curr_val
                curr_val += 1
            top += 1
            
            # Move Down: right column
            for i in range(top, bottom + 1):
                matrix[i][right] = curr_val
                curr_val += 1
            right -= 1
            
            # Move Left: bottom row
            for i in range(right, left - 1, -1):
                matrix[bottom][i] = curr_val
                curr_val += 1
            bottom -= 1
            
            # Move Up: left column
            for i in range(bottom, top - 1, -1):
                matrix[i][left] = curr_val
                curr_val += 1
            left += 1
            
        return matrix
