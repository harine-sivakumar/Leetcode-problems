class Solution:
    def firstMissingPositive(self, nums: List[int]) -> int:
        n = len(nums)
        for i in range(n):
            while 1 <= nums[i] <= n and nums[nums[i] - 1] != nums[i]:
                # Using a temp variable for the target index is safer in Python 
                # to avoid issues with multiple index evaluations in one line
                correct_pos = nums[i] - 1
                nums[i], nums[correct_pos] = nums[correct_pos], nums[i]
                
        for i in range(n):
            if nums[i] != i + 1:
                return i + 1
        return n + 1
