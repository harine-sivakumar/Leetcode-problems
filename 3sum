class Solution:
    def threeSum(self, nums: list[int]) -> list[list[int]]:
        res = []
        nums.sort()  # Sort to use two-pointer logic and skip duplicates easily
        
        for i, a in enumerate(nums):
            # Skip if the current number is the same as the previous to avoid duplicate triplets
            if i > 0 and a == nums[i - 1]:
                continue
            
            # If current number is > 0, the remaining sum can't be 0 since the list is sorted
            if a > 0:
                break
                
            l, r = i + 1, len(nums) - 1
            while l < r:
                three_sum = a + nums[l] + nums[r]
                if three_sum > 0:
                    r -= 1  # Decrease sum
                elif three_sum < 0:
                    l += 1  # Increase sum
                else:
                    res.append([a, nums[l], nums[r]])
                    l += 1
                    r -= 1
                    # Skip duplicate values for the left pointer
                    while nums[l] == nums[l - 1] and l < r:
                        l += 1
                        
        return res
