class Solution:
    def uniquePathsWithObstacles(self, obstacleGrid: list[list[int]]) -> int:
        if not obstacleGrid or obstacleGrid[0][0] == 1:
            return 0
        
        m, n = len(obstacleGrid), len(obstacleGrid[0])
        # Use a 1D array to keep track of paths for the current row
        dp = [0] * n
        dp[0] = 1 # Starting point

        for r in range(m):
            for c in range(n):
                if obstacleGrid[r][c] == 1:
                    dp[c] = 0
                elif c > 0:
                    # Current paths = paths from above (dp[c]) + paths from left (dp[c-1])
                    dp[c] += dp[c-1]
                
        return dp[-1]
