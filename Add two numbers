# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
from typing import Optional

class Solution:
    def addTwoNumbers(self, l1: Optional[ListNode], l2: Optional[ListNode]) -> Optional[ListNode]:
        dummy = ListNode()
        # 'curr' pointer tracks the current node in the result list
        curr = dummy
        carry = 0

        # Continue as long as there are nodes in either list or a carry value exists
        while l1 or l2 or carry:
            # Get the values of the current nodes, defaulting to 0 if a list is exhausted
            val1 = l1.val if l1 else 0
            val2 = l2.val if l2 else 0

            # Calculate the sum and the new carry
            total = val1 + val2 + carry
            carry = total // 10
            digit = total % 10

            # Create a new node in the result list
            curr.next = ListNode(digit)
            curr = curr.next

            # Move the pointers in the input lists forward
            if l1:
                l1 = l1.next
            if l2:
                l2 = l2.next

        # The result is the next node after the dummy head
        return dummy.next

        
